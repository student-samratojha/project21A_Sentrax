<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sentrax</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-yellow-50 min-h-screen font-sans text-gray-800">
    <nav class="bg-white shadow-sm p-4 mb-8 border-b border-yellow-200">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold text-yellow-700">Sentrax</h1>
            <div class="flex items-center space-x-4">
                <span class="flex items-center text-xs font-bold bg-green-100 text-green-800 py-1 px-3 rounded-full border border-green-200">
                    <i data-lucide="shield-check" class="w-3 h-3 mr-1"></i>
                    Online
                </span>
                <a href="/auth/logout" class="flex items-center text-sm font-bold text-red-600 hover:text-red-800">
                    <i data-lucide="log-out" class="w-4 h-4 mr-1"></i>
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
            <div class="bg-yellow-100 p-6 border-b border-yellow-200">
                <div class="flex items-center mb-2">
                    <div class="p-3 bg-white rounded-full text-yellow-600 mr-4 shadow-sm border border-yellow-200">
                        <i data-lucide="user" class="w-8 h-8"></i>
                    </div>
                    <h2 class="text-3xl font-bold text-yellow-800">Hello, <%= typeof user !== 'undefined' ? user.name : 'Explorer' %>!</h2>
                </div>
                <p class="text-yellow-700 opacity-80">You have successfully accessed the secure area.</p>
            </div>
            
            <div class="p-8">
                <h3 class="text-lg font-semibold mb-4 text-gray-700 uppercase tracking-wider">Session Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-red-100 rounded-xl border border-red-200 flex items-center">
                        <i data-lucide="mail" class="w-5 h-5 text-red-600 mr-3"></i>
                        <div>
                        <p class="text-xs text-red-600 uppercase font-bold">Email Storage</p>
                        <p class="text-lg font-mono text-red-900"><%= typeof user !== 'undefined' ? user.email : 'N/A' %></p>
                        </div>
                    </div>
                    <a href="/posts/feed" class="p-4 bg-green-100 rounded-xl border border-green-200 flex items-center justify-between group">
                        <div class="flex items-center">
                            <i data-lucide="layout-list" class="w-5 h-5 text-green-700 mr-3"></i>
                            <span class="text-sm font-bold text-green-800 uppercase">Community Feed</span>
                        </div>
                        <i data-lucide="arrow-right" class="w-4 h-4 text-green-600 group-hover:translate-x-1 transition"></i>
                    </a>
                </div>
            </div>
        </div>
    </main>
    <script>lucide.createIcons();</script>
</body>
</html>