<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Sentrax</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-yellow-50 min-h-screen font-sans text-gray-800">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm p-4 border-b border-yellow-200 sticky top-0 z-20">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <div class="p-2 bg-yellow-100 rounded-lg text-yellow-700 border border-yellow-200">
                    <i data-lucide="shield-check" class="w-5 h-5"></i>
                </div>
                <h1 class="text-xl font-bold text-gray-700">Sentrax <span class="text-yellow-500">Admin</span></h1>
            </div>
            <div class="flex items-center space-x-6">
                <a href="/secure/user" class="flex items-center text-sm font-medium hover:text-yellow-600 transition">
                    <i data-lucide="layout-dashboard" class="w-4 h-4 mr-1"></i>
                    Dashboard
                </a>
                <a href="/auth/logout" class="flex items-center bg-red-100 text-red-700 px-4 py-2 rounded-lg text-sm font-bold border border-red-200 hover:bg-red-200 transition">
                    <i data-lucide="log-out" class="w-4 h-4 mr-1"></i>
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-6">
        <!-- System Overview Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-green-100 p-6 rounded-2xl border border-green-200 shadow-sm flex items-center justify-between">
                <div>
                <h3 class="text-green-800 text-sm font-bold uppercase tracking-wider mb-2">Total Users</h3>
                <p class="text-4xl font-black text-green-900"><%= typeof users !== 'undefined' ? users.length : 0 %></p>
                </div>
                <i data-lucide="users" class="w-10 h-10 text-green-600 opacity-40"></i>
            </div>
            <div class="bg-yellow-100 p-6 rounded-2xl border border-yellow-200 shadow-sm flex items-center justify-between">
                <div>
                <h3 class="text-yellow-800 text-sm font-bold uppercase tracking-wider mb-2">Active Sessions</h3>
                <p class="text-4xl font-black text-yellow-900">Live</p>
                </div>
                <i data-lucide="activity" class="w-10 h-10 text-yellow-600 opacity-40"></i>
            </div>
            <div class="bg-red-100 p-6 rounded-2xl border border-red-200 shadow-sm flex items-center justify-between">
                <div>
                <h3 class="text-red-800 text-sm font-bold uppercase tracking-wider mb-2">Security Alerts</h3>
                <p class="text-4xl font-black text-red-900">0</p>
                </div>
                <i data-lucide="shield-alert" class="w-10 h-10 text-red-600 opacity-40"></i>
            </div>
        </div>

        <!-- Detailed Information Table -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                <h2 class="text-lg font-bold text-gray-700 uppercase tracking-tight">Registered Users</h2>
                <button class="text-xs bg-gray-100 hover:bg-gray-200 px-3 py-1 rounded-full font-semibold transition">Refresh Data</button>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50">
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                                <div class="flex items-center"><i data-lucide="hash" class="w-3 h-3 mr-1"></i> ID</div>
                            </th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                                <div class="flex items-center"><i data-lucide="user" class="w-3 h-3 mr-1"></i> User Info</div>
                            </th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                                <div class="flex items-center"><i data-lucide="mail" class="w-3 h-3 mr-1"></i> Email</div>
                            </th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                                <div class="flex items-center"><i data-lucide="check-circle" class="w-3 h-3 mr-1"></i> Status</div>
                            </th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase text-right">
                                <div class="flex items-center justify-end"><i data-lucide="settings" class="w-3 h-3 mr-1"></i> Actions</div>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (typeof users !== 'undefined' && users.length > 0) { %>
                            <% users.forEach(user => { %>
                                <tr class="group hover:bg-yellow-50 transition">
                                    <td class="px-6 py-4 font-mono text-xs text-gray-400"><%= user._id.toString().substring(0, 8) %>...</td>
                                    <td class="px-6 py-4 font-bold text-gray-800"><%= user.username %></td>
                                    <td class="px-6 py-4 text-gray-600"><%= user.email %></td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 bg-green-100 text-green-700 text-[10px] font-bold rounded uppercase border border-green-200">Verified</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <form action="/admin/delete-user/<%= user._id %>" method="POST" onsubmit="return confirm('Permanently delete this user?');">
                                            <button type="submit" class="flex items-center ml-auto text-red-500 hover:text-red-700 font-bold text-sm transition">
                                                <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="px-6 py-12 text-center text-gray-400 italic">
                                    No users found in the database.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Server Info Footer -->
        <div class="mt-8 p-6 bg-white rounded-2xl border border-gray-200">
            <div class="flex items-center mb-4">
                <i data-lucide="database" class="w-4 h-4 text-gray-500 mr-2"></i>
                <h3 class="text-sm font-bold text-gray-500 uppercase">Database Storage Info</h3>
            </div>
            <div class="flex space-x-4">
                <div class="flex-1 p-4 rounded-xl bg-yellow-50 border border-dashed border-yellow-300">
                    <span class="text-[10px] block font-bold text-gray-400 uppercase">Mongo URI</span>
                    <span class="text-xs font-mono text-gray-500">Connected to Cluster-0</span>
                </div>
                <div class="flex-1 p-4 rounded-xl bg-green-50 border border-dashed border-green-300">
                    <span class="text-[10px] block font-bold text-green-400 uppercase">Collection Name</span>
                    <span class="text-xs font-mono text-gray-500">users | sessions</span>
                </div>
            </div>
        </div>
    </main>
    <script>lucide.createIcons();</script>
</body>
</html>