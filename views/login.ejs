<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sentrax</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-green-100 min-h-screen flex items-center justify-center font-sans text-gray-800">
    <div class="max-w-md w-full bg-white p-8 rounded-xl shadow-lg border-t-4 border-green-400">
        <h2 class="text-3xl font-bold mb-6 text-green-700 text-center">Sign In</h2>
        
        <form action="/auth/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                <input type="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-200 focus:border-green-400 outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input type="password" name="password" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-200 focus:border-green-400 outline-none">
            </div>
            
            <button type="submit" class="w-full bg-green-100 hover:bg-green-200 text-green-800 font-bold py-3 rounded-lg border border-green-300 transition mt-4">
                Login
            </button>
        </form>
        
        <div class="mt-6 text-center">
            <p class="text-sm text-gray-600">
                Don't have an account? 
                <a href="/auth/register" class="text-green-600 font-semibold hover:underline">Register here</a>
            </p>
            <a href="/" class="block mt-4 text-xs text-gray-400 hover:text-gray-600">Back to Home</a>
        </div>
    </div>
</body>
</html>